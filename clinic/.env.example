# Copy to clinic/.env and fill in for a real deploy. Anything left unset uses the
# (dev) default baked into docker-compose.yml, so the stack also runs with no .env.
# NEXT_PUBLIC_* are baked into the frontend at build time — rebuild after changing.

# --- Database credentials (set for any real deploy) ---
POSTGRES_USER=clinic_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=clinic_db

# --- Auth signing secret, base64, 32+ bytes (set for any real deploy) ---
APP_JWT_SECRET=change-me-base64-32-bytes

# --- Initial admin login (seeded on first boot) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- Frontend -> backend API URL (public URL the browser hits) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Browser origins the backend allows via CORS (comma-separated) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
